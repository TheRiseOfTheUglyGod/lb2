<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ru.kafpin.lb2.TriangleController"
      stylesheets="@../css/style.css">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Проверка треугольника" styleClass="header">
        <font>
            <Font size="24.0"/>
        </font>
    </Label>

    <GridPane hgap="10.0" vgap="10.0">
        <padding>
            <Insets top="10"/>
        </padding>

        <!-- Сторона a -->
        <Label text="Сторона a:" GridPane.rowIndex="0" GridPane.columnIndex="0"
               GridPane.halignment="RIGHT" GridPane.valignment="CENTER"/>
        <TextField fx:id="tfA" GridPane.rowIndex="0" GridPane.columnIndex="1"
                   prefWidth="80"/>
        <Slider fx:id="sliderA" GridPane.rowIndex="0" GridPane.columnIndex="2"
                prefWidth="200" min="1.0" max="20.0" value="1.0"
                blockIncrement="1.0" showTickLabels="true" showTickMarks="true"
                majorTickUnit="1.0" minorTickCount="0" snapToTicks="true"/>

        <!-- Сторона b -->
        <Label text="Сторона b:" GridPane.rowIndex="1" GridPane.columnIndex="0"
               GridPane.halignment="RIGHT" GridPane.valignment="CENTER"/>
        <TextField fx:id="tfB" GridPane.rowIndex="1" GridPane.columnIndex="1"
                   prefWidth="80"/>
        <Slider fx:id="sliderB" GridPane.rowIndex="1" GridPane.columnIndex="2"
                prefWidth="200" min="1.0" max="20.0" value="1.0"
                blockIncrement="1.0" showTickLabels="true" showTickMarks="true"
                majorTickUnit="1.0" minorTickCount="0" snapToTicks="true"/>

        <!-- Сторона c -->
        <Label text="Сторона c:" GridPane.rowIndex="2" GridPane.columnIndex="0"
               GridPane.halignment="RIGHT" GridPane.valignment="CENTER"/>
        <TextField fx:id="tfC" GridPane.rowIndex="2" GridPane.columnIndex="1"
                   prefWidth="80"/>
        <Slider fx:id="sliderC" GridPane.rowIndex="2" GridPane.columnIndex="2"
                prefWidth="200" min="1.0" max="20.0" value="1.0"
                blockIncrement="1.0" showTickLabels="true" showTickMarks="true"
                majorTickUnit="1.0" minorTickCount="0" snapToTicks="true"/>
    </GridPane>

    <HBox spacing="10.0">
        <Button fx:id="btnCheck" text="Проверить" onAction="#onCheck" prefWidth="100"/>
        <Button fx:id="btnReset" text="Сброс" onAction="#onReset" prefWidth="100"/>
    </HBox>

    <Label fx:id="lblResult" wrapText="true"/>
</VBox>